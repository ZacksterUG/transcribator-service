
# minio
MINIO_ROOT_USER=myuser
MINIO_ROOT_PASSWORD=mypass

# postgreSQL
POSTGRESQL_USER=postgres
POSTGRESQL_PASSWORD=postgres

# Keycloak Configuration
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_VERIFY_SSL=true

# API Gateway
GATEWAY_PORT=10000
AUTH_TYPE=keycloak  # keycloak or service_token

# Service Token Auth (only if AUTH_TYPE=service_token)
SERVICE_TOKENS=trusted-service-token-1,trusted-service-token-2

# NATS Configuration
NATS_SERVERS=nats://nats:4222
NATS_VERBOSE=true
NATS_PEDANTIC=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass
SYNC_REDIS_DB=0
ASYNC_REDIS_DB=1

# Sync Service - Model Configuration
MODEL_TOKENS=/app/models/vosk-model-streaming-ru/tokens.txt
MODEL_ENCODER=/app/models/vosk-model-streaming-ru/encoder.onnx
MODEL_DECODER=/app/models/vosk-model-streaming-ru/decoder.onnx
MODEL_JOINER=/app/models/vosk-model-streaming-ru/joiner.onnx

# Sync Service - Model Parameters
SAMPLE_RATE=16000
MODEL_NUM_THREADS=4
FEATURE_DIM=80
DECODING_METHOD=greedy_search

# Sync Service - Endpoint Detection
ENABLE_ENDPOINT_DETECTION=true
RULE1_MIN_TRAILING_SILENCE=2.4
RULE2_MIN_TRAILING_SILENCE=1.2
RULE3_MIN_UTTERANCE_LENGTH=20.0

# Sync Service - Topics
BASE_TOPIC=transcriber.sync
INIT_TOPIC=transcriber.sync.init
PROCESSING_TOPIC_PREFIX=transcriber.sync.processing
RESPONSE_TOPIC_PREFIX=transcriber.sync.response
STATUS_TOPIC_PREFIX=transcriber.sync.status

# Sync Service - Session Configuration
MAX_ACTIVE_STREAMS=100
JOB_ACTIVE_TIMEOUT=20

# Sync Service - Logging
LOG_LEVEL=INFO
DEBUG=false

# Async Service - Topics
REQUEST_TOPIC=transcriber.async.request
RESPONSE_TOPIC=transcriber.async.response

# Async Service - Model Configuration
MODEL_TYPE=faster-whisper
MODEL_PATH_OR_SIZE=base
MODEL_DEVICE=cpu
MODEL_COMPUTE_TYPE=int8
MODEL_NUM_WORKERS=1

# MinIO Storage
MINIO_URL=http://minio:9000
MINIO_USER=myuser
MINIO_PASSWORD=mypass
MINIO_BUCKET=transcriptions

# Temp Directory
TEMP_DIR=/app/temp