# NATS Configuration
NATS_SERVERS=nats://localhost:4222

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Model - Paths to files
MODEL_TOKENS=../../models/vosk-model-streaming-ru/tokens.txt
MODEL_ENCODER=../../models/vosk-model-streaming-ru/encoder.onnx
MODEL_DECODER=../../models/vosk-model-streaming-ru/decoder.onnx
MODEL_JOINER=../../models/vosk-model-streaming-ru/joiner.onnx

# Model Parameters
SAMPLE_RATE=16000
MODEL_NUM_THREADS=4
FEATURE_DIM=80
DECODING_METHOD=greedy_search

# Endpoint Detection
ENABLE_ENDPOINT_DETECTION=true
RULE1_MIN_TRAILING_SILENCE=2.4
RULE2_MIN_TRAILING_SILENCE=1.2
RULE3_MIN_UTTERANCE_LENGTH=20.0

# Topics
BASE_TOPIC=transcriber.sync
INIT_TOPIC=transcriber.sync.init
PROCESSING_TOPIC_PREFIX=transcriber.sync.processing
RESPONSE_TOPIC_PREFIX=transcriber.sync.response
STATUS_TOPIC_PREFIX=transcriber.sync.status

# Session Configuration
MAX_ACTIVE_STREAMS=100
JOB_ACTIVE_TIMEOUT=20

# Logging
LOG_LEVEL=INFO
